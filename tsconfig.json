{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    // 关闭 verbatimModuleSyntax 以允许 import type 与 value 混合导入
    "verbatimModuleSyntax": false,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    // 忽略 TypeScript 6.0 弃用警告（待相关依赖更新后移除）
    "ignoreDeprecations": "6.0",
    "paths": {
      "@server": ["server"],
      "@server/*": ["server/*"],
      "@markdown": ["app/markdown"],
      "@markdown/*": ["app/markdown/*"],
      "@content": ["app/content"],
      "@content/*": ["app/content/*"],
      "@database": ["app/database"],
      "@database/*": ["app/database/*"],
      "@progress": ["app/progress"],
      "@progress/*": ["app/progress/*"],
      "~/*": ["app/*"],
      "~~/*": ["./*"]
    }
  },
  "include": [
    ".nuxt/nuxt.d.ts",
    "app/**/*.ts",
    "app/**/*.js",
    "app/**/*.vue",
    "app/**/*.d.ts",
    "server/**/*.ts",
    "server/**/*.js",
    "drizzle.config.ts",
    "nuxt.config.ts",
    "eslint.config.mjs"
  ],
  "exclude": [
    "node_modules",
    ".output",
    ".vercel",
    "dist"
  ]
}
