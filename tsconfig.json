{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": false,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@shared": ["app/shared"],
      "@shared/*": ["app/shared/*"],
      "@server": ["server"],
      "@server/*": ["server/*"],
      "@core": ["app/core"],
      "@core/*": ["app/core/*"],
      "@me": ["app/core/markdown-engine/src"],
      "@me/*": ["app/core/markdown-engine/src/*"],
      "@ce": ["app/core/content-engine"],
      "@ce/*": ["app/core/content-engine/*"],
      "~/*": ["app/*"],
      "~~/*": ["./*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.js",
    "app/**/*.vue",
    "app/**/*.d.ts",
    "app/core/**/*.ts",
    "server/**/*.ts",
    "server/**/*.js",
    "content/**/*.ts",
    "content/**/*.js"
  ],
  "exclude": [
    "node_modules",
    ".nuxt",
    ".output",
    ".vercel",
    "dist"
  ]
}
