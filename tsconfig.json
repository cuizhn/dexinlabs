{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": false,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@shared": ["app/shared"],
      "@shared/*": ["app/shared/*"],
      "@server": ["server"],
      "@server/*": ["server/*"],
      "@markdown": ["app/markdown"],
      "@markdown/*": ["app/markdown/*"],
      "@content": ["app/content"],
      "@content/*": ["app/content/*"],
      "@database": ["app/database"],
      "@database/*": ["app/database/*"],
      "~/*": ["app/*"],
      "~~/*": ["./*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.js",
    "app/**/*.vue",
    "app/**/*.d.ts",
    "app/core/**/*.ts",
    "server/**/*.ts",
    "server/**/*.js",
    "drizzle.config.ts"
  ],
  "exclude": [
    "node_modules",
    ".nuxt",
    ".output",
    ".vercel",
    "dist"
  ]
}
