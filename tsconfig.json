{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": false,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@boot": ["app/boot"],
      "@boot/*": ["app/boot/*"],
      "@data": ["app/data"],
      "@data/*": ["app/data/*"],
      "@shared": ["app/shared"],
      "@shared/*": ["app/shared/*"],
      "@server": ["server"],
      "@server/*": ["server/*"],
      "@me": ["markdown-engine/src"],
      "@me/*": ["markdown-engine/src/*"],
      "@ce": ["content-engine"],
      "@ce/*": ["content-engine/*"],
      "~/*": ["app/*"],
      "~~/*": ["./*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.js",
    "app/**/*.vue",
    "app/**/*.d.ts",
    "drizzle/**/*.ts",
    "server/**/*.ts",
    "server/**/*.js",
    "content/**/*.ts",
    "content/**/*.js",
    "markdown-engine/**/*.ts",
    "content-engine/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".nuxt",
    ".output",
    ".vercel",
    "dist"
  ]
}
